# RecallAI Environment Configuration
# Copy this file to .env and update with your values

# Application
APP_NAME=RecallAI
APP_VERSION=1.0.0
DEBUG=True

# Security (IMPORTANT: Change these in production!)
SECRET_KEY=your-secret-key-here-use-openssl-rand-hex-32-to-generate
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=recallai

# CORS (Update with your frontend URL in production)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# AI Configuration (Add your API keys)
GEMINI_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# Optional: Redis (for caching and task queue)
# REDIS_URL=redis://localhost:6379
